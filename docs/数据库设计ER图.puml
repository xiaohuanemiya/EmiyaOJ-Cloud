@startuml EmiyaOJ-ER-Blog

' ============================================================
' EmiyaOJ-Cloud 数据库 ER 图 — emiya_oj_blog (博客库)
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam defaultFontSize 11

title **EmiyaOJ-Cloud — 数据库 ER 图: emiya_oj_blog (博客社区库)**

' ============================================================
' 博客表
' ============================================================
entity "blog" as blog {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **user_id** : BIGINT <<FK→user.id>>
    * **title** : VARCHAR(255)
    * **content** : TEXT
    * **blog_type** : TINYINT <<0普通,1题解>>
    problem_id : BIGINT <<FK→problem.id, 题解关联>>
    view_count : INT
    like_count : INT
    audit_status : TINYINT <<0待审,1通过,2拒绝,3人工>>
    audit_task_id : VARCHAR(64)
    audit_reason : VARCHAR(1000)
    audit_labels : VARCHAR(512)
    audit_time : DATETIME
    create_time : DATETIME
    update_time : DATETIME
    deleted : TINYINT
    --
    <<UK (user_id, problem_id, blog_type, deleted)>>
}

' ============================================================
' 评论表
' ============================================================
entity "blog_comment" as blog_comment {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **blog_id** : BIGINT <<FK→blog.id>>
    * **user_id** : BIGINT <<FK→user.id>>
    * **content** : TEXT
    audit_status : TINYINT <<0待审,1通过,2拒绝,3人工>>
    audit_task_id : VARCHAR(64)
    audit_reason : VARCHAR(1000)
    audit_labels : VARCHAR(512)
    audit_time : DATETIME
    create_time : DATETIME
    update_time : DATETIME
    deleted : TINYINT
}

' ============================================================
' 点赞表
' ============================================================
entity "blog_like" as blog_like {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **user_id** : BIGINT <<FK→user.id>>
    * **blog_id** : BIGINT <<FK→blog.id>>
    create_time : DATETIME
    deleted : TINYINT
    --
    <<UK (user_id, blog_id)>>
}

' ============================================================
' 收藏表
' ============================================================
entity "blog_star" as blog_star {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **user_id** : BIGINT <<FK→user.id>>
    * **blog_id** : BIGINT <<FK→blog.id>>
    create_time : DATETIME
    deleted : TINYINT
    --
    <<UK (user_id, blog_id)>>
    <<TRIGGER: after_blog_star_insert/delete → 更新user_blog.star_count>>
}

' ============================================================
' 博客标签表
' ============================================================
entity "blog_tag" as blog_tag {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **tag** : VARCHAR(255)
    * **desc** : VARCHAR(255)
}

' ============================================================
' 博客标签关联表
' ============================================================
entity "blog_tag_association" as blog_tag_association {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **blog_id** : BIGINT <<FK→blog.id>>
    * **tag_id** : BIGINT <<FK→blog_tag.id>>
}

' ============================================================
' 图片表 (MinIO 存储)
' ============================================================
entity "blog_picture" as blog_picture {
    * **id** : BIGINT <<PK, AUTO>>
    --
    * **user_id** : BIGINT <<FK→user.id>>
    blog_id : BIGINT <<FK→blog.id>>
    * **object_name** : VARCHAR(512) <<UK>>
    * **url** : VARCHAR(1024)
    * **content_type** : VARCHAR(100)
    * **size** : BIGINT
    original_filename : VARCHAR(255)
    create_time : DATETIME
    deleted : TINYINT
}

' ============================================================
' 用户博客统计表 (触发器维护)
' ============================================================
entity "user_blog" as user_blog {
    * **user_id** : BIGINT <<PK, FK→user.id>>
    --
    username : VARCHAR(50)
    nickname : VARCHAR(50)
    blog_count : INT
    star_count : INT
    create_time : DATETIME
    --
    <<TRIGGER维护>>
    <<after_blog_insert/delete → blog_count>>
    <<after_blog_star_insert/delete → star_count>>
}

' ============================================================
' 关系定义
' ============================================================

' Blog ↔ Comment
blog ||--o{ blog_comment : "1:N"

' Blog ↔ Like (多对多)
blog ||--o{ blog_like : "1:N"

' Blog ↔ Star (多对多)
blog ||--o{ blog_star : "1:N"

' Blog ↔ Tag (多对多)
blog ||--o{ blog_tag_association : "1:N"
blog_tag_association }o--|| blog_tag : "N:1"

' Blog ↔ Picture
blog ||--o{ blog_picture : "1:N (可选)"

' ============================================================
' 审核字段说明
' ============================================================
note right of blog
  **内容审核流程**
  ───────────────
  ① 发布博客/评论 → audit_status=0
  ② RabbitMQ 投递审核任务
  ③ Moderation Service 消费
  ④ 阿里云 ScanText API
  ⑤ Feign 回写 audit_status
     · pass → 1 (APPROVED)
     · block → 2 (REJECTED)
     · review → 3 (MANUAL_REVIEW)
  ⑥ 管理员可人工修改状态
  
  **MySQL 触发器**
  ──────────────
  · after_blog_insert: 通过后 blog_count+1
  · after_blog_delete: 取消通过后 blog_count-1
  · after_blog_star_insert: star_count+1
  · after_blog_star_delete: star_count-1
end note

@enduml

' ================================================================

@startuml EmiyaOJ-ER-CrossDB

' ============================================================
' EmiyaOJ-Cloud 跨库逻辑关系总览
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam defaultFontSize 10

title **EmiyaOJ-Cloud — 跨库逻辑关系总览 (Logical FK Map)**

' 数据库边界
package "emiya_oj_auth" #E3F2FD {
    entity "user" as user_cross {
        id : BIGINT <<PK>>
    }
    entity "role" as role_cross {
        id : BIGINT <<PK>>
    }
    entity "permission" as permission_cross {
        id : BIGINT <<PK>>
    }
}

package "emiya_oj_problem" #E8F5E9 {
    entity "problem" as problem_cross {
        id : BIGINT <<PK>>
    }
    entity "test_case" as test_case_cross {
        id : BIGINT <<PK>>
    }
    entity "language" as language_cross {
        id : BIGINT <<PK>>
    }
    entity "contest" as contest_cross {
        id : BIGINT <<PK>>
    }
    entity "contest_problem" as cp_cross {
        id : BIGINT <<PK>>
    }
    entity "problem_set" as problem_set_cross {
        id : BIGINT <<PK>>
    }
}

package "emiya_oj_judge" #FFF9C4 {
    entity "submission" as submission_cross {
        id : BIGINT <<PK>>
    }
    entity "submission_judge_result" as sjr_cross {
        id : BIGINT <<PK>>
    }
    entity "submission_case_result" as scr_cross {
        id : BIGINT <<PK>>
    }
    entity "message_event" as me_cross {
        id : BIGINT <<PK>>
    }
}

package "emiya_oj_blog" #F3E5F5 {
    entity "blog" as blog_cross {
        id : BIGINT <<PK>>
    }
    entity "blog_comment" as bc_cross {
        id : BIGINT <<PK>>
    }
    entity "user_blog" as ub_cross {
        user_id : BIGINT <<PK>>
    }
}

' 跨库逻辑外键关系 (虚线)
user_cross ..> problem_cross : "author_id"
user_cross ..> contest_cross : "creator_id"
user_cross ..> problem_set_cross : "creator_id"
user_cross ..> submission_cross : "user_id"
user_cross ..> blog_cross : "user_id"
user_cross ..> bc_cross : "user_id"
user_cross ..> ub_cross : "user_id (PK/FK)"

problem_cross ..> submission_cross : "problem_id"
language_cross ..> submission_cross : "language_id"
contest_cross ..> submission_cross : "contest_id"
cp_cross ..> submission_cross : "contest_problem_id"
test_case_cross ..> scr_cross : "test_case_id"
problem_cross ..> blog_cross : "problem_id (题解)"

note bottom of submission_cross
  **跨库数据流**
  ──────────────
  Judge Service 通过 Feign
  调用 Problem Service 获取:
  · problem (题目信息)
  · test_case (测试用例)
  · language (语言配置)
  
  Judge Service 通过 Feign
  调用 Auth Service 获取:
  · user (用户信息)
  
  Blog Service 通过 Feign
  调用 Problem Service 获取:
  · problem (题解关联题目)
  
  内容审核通过 RabbitMQ
  解耦 Blog ↔ Moderation
  Moderation 通过 Feign 回写
  Blog Service 审核结果
end note

@enduml
