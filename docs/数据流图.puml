@startuml EmiyaOJ-Cloud-DFD-Level0

' ============================================================
' EmiyaOJ-Cloud 数据流图 (DFD) — Level 0 上下文图
' 遵循 Yourdon/DeMarco 数据流图规范
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam roundcorner 8
skinparam defaultFontSize 11
skinparam packageStyle rectangle
skinparam node {
    BorderColor #333333
    FontSize 11
}
skinparam rectangle {
    BorderColor #333333
    FontSize 11
}
