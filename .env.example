# RabbitMQ
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Internal service authentication
JUDGE_INTERNAL_TOKEN=emiyaoj-judge-internal

# Judge Feedback Agent - DeepSeek V4 Pro
DEEPSEEK_API_KEY=
JUDGE_FEEDBACK_API_URL=https://api.deepseek.com/chat/completions
JUDGE_FEEDBACK_MODEL=deepseek-v4-pro
# DeepSeek may return 200 response headers before the response body is ready.
JUDGE_FEEDBACK_TIMEOUT_SECONDS=120
JUDGE_HTTP_TIMEOUT_SECONDS=10
RABBITMQ_HEARTBEAT_SECONDS=300

# Optional fallback key names recognized by agent-service:
# JUDGE_FEEDBACK_API_KEY=
# CHAT_API_KEY=
